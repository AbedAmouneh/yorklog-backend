# ── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/yorklog"

# ── JWT ───────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-string"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# ── Email (Nodemailer) ────────────────────────────────
# Option A: Gmail App Password
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@york-press.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="YorkLog <noreply@york-press.com>"

# Option B: SendGrid
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT=587
# SMTP_USER="apikey"
# SMTP_PASS="your-sendgrid-api-key"

# ── Cron ──────────────────────────────────────────────
# Daily reminder time (Lebanon = UTC+3)
REMINDER_CRON="0 14 * * 1-5"
# 14:00 UTC = 17:00 Beirut (UTC+3) — runs Mon–Fri
