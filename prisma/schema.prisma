generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  employee
  dept_manager
  hr_finance
  org_admin
  super_admin
}

enum ProjectStatus {
  active
  archived
}

enum EntryStatus {
  submitted
  approved
  pending_edit
  rejected
}

enum EditRequestStatus {
  pending
  approved
  rejected
}

enum NotificationType {
  edit_submitted
  edit_approved
  edit_rejected
  daily_reminder
  project_assigned
}

// ── Models ────────────────────────────────────────────────────────────────────

model Department {
  id             String   @id @default(uuid())
  name           String   @unique
  maxDailyHours  Int      @default(8) @map("max_daily_hours")
  headUserId     String?  @map("head_user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  headUser User?  @relation("DepartmentHead", fields: [headUserId], references: [id])
  users    User[]

  @@map("departments")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(employee)
  notifyEmail  Boolean  @default(true) @map("notify_email")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  departmentId         String?             @map("department_id")
  department           Department?         @relation(fields: [departmentId], references: [id])
  ledDepartments       Department[]        @relation("DepartmentHead")
  timesheetEntries     TimesheetEntry[]
  projectAssignments   ProjectAssignment[]
  editRequestsMade     EditRequest[]       @relation("RequestedBy")
  editRequestsReviewed EditRequest[]       @relation("ReviewedBy")
  notifications        Notification[]
  createdProjects      Project[]

  @@map("users")
}

model Project {
  id            String        @id @default(uuid())
  name          String        @unique
  description   String?
  status        ProjectStatus @default(active)
  maxDailyHours Int?          @map("max_daily_hours")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  createdById String              @map("created_by_id")
  createdBy   User                @relation(fields: [createdById], references: [id])
  taskTypes   TaskType[]
  assignments ProjectAssignment[]
  entries     TimesheetEntry[]

  @@map("projects")
}

model TaskType {
  id            String   @id @default(uuid())
  name          String
  isQuickAccess Boolean  @default(false) @map("is_quick_access")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  projectId String         @map("project_id")
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entries   TimesheetEntry[]

  @@unique([projectId, name])
  @@map("task_types")
}

model ProjectAssignment {
  id         String   @id @default(uuid())
  assignedAt DateTime @default(now()) @map("assigned_at")

  // Relations
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_assignments")
}

model TimesheetEntry {
  id           String      @id @default(uuid())
  date         DateTime    @db.Date
  totalMinutes Int         @map("total_minutes")
  taskSummary  String      @map("task_summary") @db.VarChar(255)
  description  String?     @db.VarChar(1000)
  status       EntryStatus @default(submitted)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  // Relations
  userId     String        @map("user_id")
  user       User          @relation(fields: [userId], references: [id])
  projectId  String        @map("project_id")
  project    Project       @relation(fields: [projectId], references: [id])
  taskTypeId String        @map("task_type_id")
  taskType   TaskType      @relation(fields: [taskTypeId], references: [id])
  editRequests EditRequest[]

  @@map("timesheet_entries")
}

model EditRequest {
  id              String            @id @default(uuid())
  originalData    Json              @map("original_data")
  newData         Json              @map("new_data")
  reason          String?
  status          EditRequestStatus @default(pending)
  rejectionReason String?           @map("rejection_reason")
  createdAt       DateTime          @default(now()) @map("created_at")
  reviewedAt      DateTime?         @map("reviewed_at")

  // Relations
  entryId       String         @map("entry_id")
  entry         TimesheetEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  requestedById String         @map("requested_by_id")
  requestedBy   User           @relation("RequestedBy", fields: [requestedById], references: [id])
  reviewedById  String?        @map("reviewed_by_id")
  reviewedBy    User?          @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@map("edit_requests")
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  relatedId String?          @map("related_id")
  createdAt DateTime         @default(now()) @map("created_at")

  // Relations
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
